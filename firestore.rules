rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net - Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "qaisarabbas6496@gmail.com" || 
        getUserData().role == 'admin'
      );
    }

    function isStaff() {
      return isSignedIn() && (
        isAdmin() || 
        getUserData().role == 'staff'
      );
    }

    function isMemberOfSameSchool(data) {
      return isSignedIn() && (
        isAdmin() || 
        (data != null && data.schoolId != null && getUserData().schoolId == data.schoolId)
      );
    }

    // --- Core Entities ---

    match /test/connection {
      allow read: if true;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /authorized_emails/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /campuses/{campusId} {
      allow read: if isSignedIn(); 
      allow write: if isAdmin();
    }

    match /school_settings/{settingId} {
      allow read: if isSignedIn(); 
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if isSignedIn(); 
      allow write: if isAdmin();
    }

    match /students/{studentId} {
      allow read, list: if isMemberOfSameSchool(resource.data); 
      allow write: if isAdmin() || isStaff();
    }

    match /staff/{staffId} {
      allow read, list: if isMemberOfSameSchool(resource.data);
      allow write: if isAdmin();
    }

    match /staff_credentials/{id} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == id);
      allow write: if isAdmin();
    }

    match /attendance/{id} {
      allow read, list: if isStaff() || 
                    (getUserData().role == 'parent' && getUserData().studentId == resource.data.targetId) || 
                    (getUserData().role == 'student' && getUserData().studentId == resource.data.targetId);
      allow write: if isStaff();
    }

    match /fee_records/{id} {
      allow read, list: if isStaff() || 
                    (getUserData().role == 'parent' && getUserData().studentId == resource.data.studentId) || 
                    (getUserData().role == 'student' && getUserData().studentId == resource.data.studentId);
      allow write: if isStaff();
    }

    match /subjects/{id} {
      allow read, list: if isMemberOfSameSchool(resource.data);
      allow write: if isAdmin() || isStaff();
    }

    match /classes/{id} {
      allow read, list: if isMemberOfSameSchool(resource.data);
      allow write: if isAdmin();
    }

    match /expenses/{id} {
      allow read, list: if isMemberOfSameSchool(resource.data);
      allow write: if isAdmin() || isStaff();
    }

    match /payroll/{id} {
      allow read, list: if isAdmin() || (isStaff() && getUserData().staffId == resource.data.staffId);
      allow write: if isAdmin();
    }

    match /inventory/{id} {
      allow read, list: if isMemberOfSameSchool(resource.data);
      allow write: if isAdmin() || isStaff();
    }

    match /exam_results/{id} {
      allow read, list: if isMemberOfSameSchool(resource.data);
      allow write: if isAdmin() || isStaff();
    }

    match /notices/{id} {
      allow read, list: if isSignedIn();
      allow write: if isAdmin();
    }

    match /tasks/{taskId} {
      allow read, list: if isMemberOfSameSchool(resource.data);
      allow create: if isStaff();
      allow update: if isStaff() || (isSignedIn() && (request.auth.uid == resource.data.assignedTo || request.auth.uid in resource.data.assignedToIds));
      allow delete: if isAdmin();
    }

    match /registrations/{id} {
      allow create: if true;
      allow read, list, write: if isAdmin();
    }
  }
}
