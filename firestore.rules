rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Global Deny & Super Admin Override ---
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && 
             (request.auth.token.email.toLowerCase() == "qaisarabbas6496@gmail.com" || 
              request.auth.uid == "UxVEF2cckyY8OmrTMgZ8ukt0udA3");
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSuperAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'admin');
    }

    function isStaff() {
      return isAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'staff');
    }

    function isApproved() {
      return isSuperAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().status == 'approved');
    }

    function belongsToSchool(schoolId) {
      return isSuperAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().schoolId == schoolId);
    }

    // --- Collections ---

    match /test/connection {
      allow read: if true;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin() || isAdmin());
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin());
    }

    match /schools/{schoolId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /campuses/{campusId} {
      allow read, list: if isSignedIn() && (isSuperAdmin() || (resource != null && belongsToSchool(resource.data.schoolId)));
      allow write: if isAdmin();
    }

    match /students/{studentId} {
      allow read, list: if isSuperAdmin() || (isApproved() && resource != null && belongsToSchool(resource.data.schoolId));
      allow write: if isStaff() && isApproved();
    }

    match /fee_records/{recordId} {
      allow read, list: if isApproved() && (belongsToSchool(resource.data.schoolId) || (isSignedIn() && getUserData().studentId == resource.data.studentId));
      allow write: if isStaff() && isApproved();
    }

    match /fee_types/{typeId} {
      allow read, list: if isApproved() && belongsToSchool(resource.data.schoolId);
      allow write: if isStaff() && isApproved();
    }

    match /payment_history/{id} {
      allow read, list: if isApproved() && (belongsToSchool(resource.data.schoolId) || (isSignedIn() && getUserData().studentId == resource.data.studentId));
      allow write: if isStaff() && isApproved();
    }

    match /notices/{id} {
      allow read, list: if isApproved();
      allow write: if isStaff() && isApproved();
    }

    match /tasks/{taskId} {
      allow read, list: if isSuperAdmin() || (isApproved() && belongsToSchool(resource.data.schoolId));
      allow create, update: if isStaff() && isApproved();
      allow delete: if isAdmin() && isApproved();
    }

    // Default match for other collections to avoid blanket denial for approved users
    match /classes/{id} { allow read, list: if isApproved() && belongsToSchool(resource.data.schoolId); allow write: if isAdmin(); }
    match /subjects/{id} { allow read, list: if isApproved() && belongsToSchool(resource.data.schoolId); allow write: if isStaff(); }
    match /attendance/{id} { allow read, list: if isApproved() && belongsToSchool(resource.data.schoolId); allow write: if isStaff(); }
    match /expenses/{id} { allow read, list: if isApproved() && belongsToSchool(resource.data.schoolId); allow write: if isAdmin(); }
    match /inventory/{id} { allow read, list: if isApproved() && belongsToSchool(resource.data.schoolId); allow write: if isStaff(); }
    match /exam_schedules/{id} { allow read, list: if isApproved() && belongsToSchool(resource.data.schoolId); allow write: if isStaff(); }
    match /exam_types/{id} { allow read, list: if isApproved() && belongsToSchool(resource.data.schoolId); allow write: if isStaff(); }
    match /exam_results/{id} { allow read, list: if isApproved() && belongsToSchool(resource.data.schoolId); allow write: if isStaff(); }
    match /results/{id} { allow read, list: if isApproved() && belongsToSchool(resource.data.schoolId); allow write: if isStaff(); }
    match /timetables/{id} { allow read, list: if isApproved() && belongsToSchool(resource.data.schoolId); allow write: if isStaff(); }
    match /staff/{id} { allow read, list: if isApproved() && belongsToSchool(resource.data.schoolId); allow write: if isAdmin(); }
    match /school_applications/{id} {
      allow read, list: if isSuperAdmin();
      allow create: if true; // Public applications
      allow update, delete: if isSuperAdmin();
    }

    match /transport_vehicles/{id} { allow read, list: if isApproved() && belongsToSchool(resource.data.schoolId); allow write: if isStaff(); }
    match /transport_routes/{id} { allow read, list: if isApproved() && belongsToSchool(resource.data.schoolId); allow write: if isStaff(); }
    match /transport_fees/{id} { allow read, list: if isApproved() && belongsToSchool(resource.data.schoolId); allow write: if isStaff(); }
    
    match /leave_requests/{id} { 
      allow read, list: if isApproved() && (belongsToSchool(resource.data.schoolId) || (isSignedIn() && request.auth.uid == resource.data.staffId));
      allow write: if isApproved() && (belongsToSchool(resource.data.schoolId));
    }
    match /leave_balances/{id} { 
      allow read, list: if isApproved() && (belongsToSchool(resource.data.schoolId) || (isSignedIn() && request.auth.uid == resource.data.staffId));
      allow write: if isAdmin();
    }

    match /shop_items/{id} { allow read, list: if isApproved() && belongsToSchool(resource.data.schoolId); allow write: if isAdmin(); }
    match /shop_sales/{id} { allow read, list: if isApproved() && belongsToSchool(resource.data.schoolId); allow write: if isStaff(); }

    match /events/{id} { allow read, list: if isApproved() && belongsToSchool(resource.data.schoolId); allow write: if isStaff(); }
    match /library_loans/{id} { allow read, list: if isApproved() && belongsToSchool(resource.data.schoolId); allow write: if isStaff(); }
    match /library_books/{id} { allow read, list: if isApproved() && belongsToSchool(resource.data.schoolId); allow write: if isStaff(); }
    match /syllabus/{id} { allow read, list: if isApproved() && belongsToSchool(resource.data.schoolId); allow write: if isStaff(); }
    match /certificates/{id} { allow read, list: if isApproved() && belongsToSchool(resource.data.schoolId); allow write: if isStaff(); }
    match /exam_papers/{id} { allow read, list: if isApproved() && belongsToSchool(resource.data.schoolId); allow write: if isStaff(); }
    match /academic_terms/{id} { allow read, list: if isApproved() && belongsToSchool(resource.data.schoolId); allow write: if isAdmin(); }

    match /school_website_settings/{id} { allow read: if true; allow write: if isAdmin(); }
    match /school_websites/{id} { allow read: if true; allow write: if isAdmin(); }
    match /website_slugs/{id} { allow read: if true; allow write: if isAdmin(); }
    match /public_admissions/{id} { 
      allow read, list: if isAdmin(); 
      allow create: if true; 
      allow update, delete: if isAdmin(); 
    }
    
    // --- Subscription System ---
    match /subscription_plans/{id} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }
    match /school_subscriptions/{schoolId} {
      allow read: if belongsToSchool(schoolId);
      allow write: if isSuperAdmin();
    }
    
    match /authorized_emails/{id} { allow read, list: if isSignedIn(); allow write: if isSuperAdmin() || isAdmin(); }
    match /settings/{id} { allow read, list: if isSuperAdmin() || (isApproved() && (id == "global" || belongsToSchool(id))); allow write: if isAdmin(); }
    match /school_settings/{id} { allow read, list: if isSuperAdmin() || (isApproved() && belongsToSchool(id)); allow write: if isAdmin(); }

  }
}
