rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        ( request.auth.token.email == "qaisarabbas6496@gmail.com" || 
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') );
    }
    
    function isStaff() {
      return isAuthenticated() && ( isAdmin() || (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'staff') );
    }

    function isParent() {
      return isAuthenticated() && userExists() && getUserData().role == 'parent';
    }

    function isStudent() {
      return isAuthenticated() && userExists() && getUserData().role == 'student';
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }

    match /campuses/{campusId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /students/{studentId} {
      allow read: if isStaff() || (isParent() && getUserData().studentId == studentId) || (isStudent() && getUserData().studentId == studentId);
      allow write: if isAdmin();
    }

    match /staff/{staffId} {
      allow read: if isStaff() || (isAuthenticated() && request.auth.uid == staffId);
      allow write: if isAdmin();
    }

    match /tasks/{taskId} {
      allow read: if isStaff() || (isAuthenticated() && request.auth.uid == resource.data.assignedTo);
      allow create: if isStaff();
      allow update: if isStaff() || (isAuthenticated() && request.auth.uid == resource.data.assignedTo);
      allow delete: if isAdmin();
    }

    match /attendance/{id} {
      allow read: if isStaff() || (isParent() && getUserData().studentId == resource.data.targetId) || (isStudent() && getUserData().studentId == resource.data.targetId);
      allow write: if isStaff();
    }

    match /exam_results/{id} {
      allow read, write: if isAdmin() || isStaff();
      allow read: if isAuthenticated() && ( (userExists() && getUserData().studentId == resource.data.studentId) );
    }

    match /results/{id} {
      allow read, write: if isAdmin() || isStaff();
      allow read: if isAuthenticated() && ( (userExists() && getUserData().studentId == resource.data.studentId) );
    }

    match /fee_types/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /fee_records/{id} {
      allow read: if isStaff() || (isParent() && getUserData().studentId == resource.data.studentId) || (isStudent() && getUserData().studentId == resource.data.studentId);
      allow write: if isAdmin() || isStaff();
    }

    match /payment_history/{id} {
      allow read: if isStaff() || (isParent() && getUserData().studentId == resource.data.studentId) || (isStudent() && getUserData().studentId == resource.data.studentId);
      allow write: if isAdmin() || isStaff();
    }

    match /expenses/{id} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /payroll/{id} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /inventory/{id} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /notices/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /bulk_messages/{id} {
      allow read, write: if isAdmin();
    }

    match /staff_credentials/{staffId} {
      allow read, write: if isAdmin();
      allow read: if isAuthenticated() && request.auth.uid == staffId;
    }

    match /syllabus/{id} {
      allow read: if isAuthenticated();
      allow write: if isStaff();
    }

    match /daily_diary/{id} {
      allow read: if isAuthenticated();
      allow write: if isStaff();
    }

    match /certificates/{id} {
      allow read: if isStaff() || (isParent() && getUserData().studentId == resource.data.studentId) || (isStudent() && getUserData().studentId == resource.data.studentId);
      allow write: if isAdmin();
    }

    match /exam_papers/{id} {
      allow read: if isStaff() || (isStudent() && getUserData().class == resource.data.class);
      allow write: if isStaff();
    }

    match /exam_types/{id} {
      allow read: if isAuthenticated();
      allow write: if isStaff();
    }

    match /exam_schedules/{id} {
      allow read: if isAuthenticated();
      allow write: if isStaff();
    }

    match /library_loans/{id} {
      allow read: if isStaff() || (isParent() && getUserData().studentId == resource.data.studentId) || (isStudent() && getUserData().studentId == resource.data.studentId);
      allow write: if isStaff();
    }

    match /events/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /transport_vehicles/{id} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /transport_routes/{id} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /transport_fees/{id} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /subjects/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /classes/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /leave_requests/{id} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update: if isAdmin() || (isStaff() && resource.data.staffId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /leave_balances/{id} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /settings/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /school_settings/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /shop_items/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isStaff();
    }

    match /shop_sales/{id} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /school_applications/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
