    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.5.0",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.1",
    "express": "^4.22.1",
    "firebase": "^12.11.0",
    "html2canvas": "^1.4.1",
    "html5-qrcode": "^2.3.8",
    "jspdf": "^4.2.1",
    "katex": "^0.16.45",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "papaparse": "^5.5.3",
    "postcss": "^8.5.13",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-katex": "^3.1.0",
    "react-router-dom": "^7.14.0",
    "react-to-print": "^3.3.0",
    "recharts": "^3.8.1",
    "resend": "^6.10.0",
    "tailwind-merge": "^3.5.0",
    "twilio": "^5.13.1",
    "vite": "^6.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/papaparse": "^5.5.2",
    "esbuild": "^0.28.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
